#!/usr/bin/env python3
"""Extract QE structures and write VASP POSCAR files without ASE parsing."""

from __future__ import annotations

import argparse
import math
import re
from pathlib import Path

BOHR_TO_ANGSTROM = 0.529177210903
FLOAT_RE = r"[+-]?(?:\d+(?:\.\d*)?|\.\d+)(?:[Ee][+-]?\d+)?"


def det3(matrix: list[list[float]]) -> float:
    return (
        matrix[0][0] * (matrix[1][1] * matrix[2][2] - matrix[1][2] * matrix[2][1])
        - matrix[0][1] * (matrix[1][0] * matrix[2][2] - matrix[1][2] * matrix[2][0])
        + matrix[0][2] * (matrix[1][0] * matrix[2][1] - matrix[1][1] * matrix[2][0])
    )


def inverse3(matrix: list[list[float]]) -> list[list[float]]:
    determinant = det3(matrix)
    if abs(determinant) < 1e-12:
        raise ValueError("Cell matrix is singular and cannot be inverted.")

    inv_det = 1.0 / determinant
    return [
        [
            (matrix[1][1] * matrix[2][2] - matrix[1][2] * matrix[2][1]) * inv_det,
            (matrix[0][2] * matrix[2][1] - matrix[0][1] * matrix[2][2]) * inv_det,
            (matrix[0][1] * matrix[1][2] - matrix[0][2] * matrix[1][1]) * inv_det,
        ],
        [
            (matrix[1][2] * matrix[2][0] - matrix[1][0] * matrix[2][2]) * inv_det,
            (matrix[0][0] * matrix[2][2] - matrix[0][2] * matrix[2][0]) * inv_det,
            (matrix[0][2] * matrix[1][0] - matrix[0][0] * matrix[1][2]) * inv_det,
        ],
        [
            (matrix[1][0] * matrix[2][1] - matrix[1][1] * matrix[2][0]) * inv_det,
            (matrix[0][1] * matrix[2][0] - matrix[0][0] * matrix[2][1]) * inv_det,
            (matrix[0][0] * matrix[1][1] - matrix[0][1] * matrix[1][0]) * inv_det,
        ],
    ]


def multiply_row_vector(vector: list[float], matrix: list[list[float]]) -> list[float]:
    return [
        sum(vector[k] * matrix[k][column] for k in range(3))
        for column in range(3)
    ]


def wrap_fractional(vector: list[float]) -> list[float]:
    return [value - math.floor(value) for value in vector]


def parse_args() -> argparse.Namespace:
    parser = argparse.ArgumentParser(
        description=(
            "Extract the first or last structure from a Quantum ESPRESSO output "
            "and write it as a VASP POSCAR file."
        )
    )
    parser.add_argument("qe_output", help="Path to the Quantum ESPRESSO output file.")
    parser.add_argument(
        "-o",
        "--output",
        help=(
            "Output filename. If omitted, uses the input basename with a .vasp suffix. "
            "With --both, uses <stem>_first.vasp and <stem>_last.vasp."
        ),
    )
    group = parser.add_mutually_exclusive_group()
    group.add_argument("--first", action="store_true", help="Extract the first structure.")
    group.add_argument("--last", action="store_true", help="Extract the last structure (default).")
    group.add_argument("--both", action="store_true", help="Extract both first and last structures.")
    return parser.parse_args()


def parse_alat_angstrom(lines: list[str]) -> float | None:
    patterns = [
        rf"lattice parameter \(alat\)\s*=\s*({FLOAT_RE})\s*a\.u\.",
        rf"celldm\(1\)\s*=\s*({FLOAT_RE})",
        rf"a_0\(\d+\)\s*=\s*({FLOAT_RE})",
    ]
    for line in lines:
        for pattern in patterns:
            match = re.search(pattern, line, flags=re.IGNORECASE)
            if match:
                return float(match.group(1)) * BOHR_TO_ANGSTROM
    return None


def header_units(header_line: str) -> str | None:
    match = re.search(r"\(([^)]*)\)", header_line)
    if not match:
        return None
    return match.group(1).strip()


def unit_scale(unit_text: str | None, alat_angstrom: float | None, kind: str) -> float | None:
    if unit_text is None:
        return alat_angstrom if alat_angstrom is not None else 1.0

    lowered = unit_text.lower()
    if "angstrom" in lowered:
        return 1.0
    if "bohr" in lowered or "a.u." in lowered:
        return BOHR_TO_ANGSTROM
    if "alat" in lowered:
        if "=" in lowered:
            match = re.search(FLOAT_RE, lowered)
            if match:
                return float(match.group(0)) * BOHR_TO_ANGSTROM
        if alat_angstrom is not None:
            return alat_angstrom
        raise ValueError(f"{kind} are given in alat units, but alat was not found in the file.")
    if "crystal" in lowered:
        return None
    raise ValueError(f"Unsupported {kind} units: {unit_text!r}")


def extract_symbol(label: str) -> str:
    match = re.match(r"([A-Z][a-z]?)", label)
    if not match:
        raise ValueError(f"Could not parse an element symbol from {label!r}.")
    return match.group(1)


def parse_geometry_block(
    lines: list[str],
    cell_idx: int,
    atomic_idx: int,
    alat_angstrom: float | None,
) -> dict:
    cell_scale = unit_scale(header_units(lines[cell_idx]), alat_angstrom, "cell")
    if cell_scale is None:
        raise ValueError("CELL_PARAMETERS cannot be given in crystal units.")

    cell = []
    for line in lines[cell_idx + 1 : cell_idx + 4]:
        tokens = line.split()
        if len(tokens) < 3:
            raise ValueError("CELL_PARAMETERS block is incomplete.")
        cell.append([cell_scale * float(tokens[i]) for i in range(3)])

    pos_units = header_units(lines[atomic_idx])
    pos_scale = unit_scale(pos_units, alat_angstrom, "atomic positions")
    inverse_cell = inverse3(cell)

    atoms = []
    for line in lines[atomic_idx + 1 :]:
        stripped = line.strip()
        if not stripped:
            break
        parts = stripped.split()
        if len(parts) < 4:
            break
        try:
            coords = [float(parts[1]), float(parts[2]), float(parts[3])]
        except ValueError:
            break

        symbol = extract_symbol(parts[0])
        if pos_units and "crystal" in pos_units.lower():
            fractional = coords
        else:
            scale = pos_scale if pos_scale is not None else 1.0
            cartesian = [scale * value for value in coords]
            fractional = multiply_row_vector(cartesian, inverse_cell)

        atoms.append((symbol, wrap_fractional(fractional)))

    if not atoms:
        raise ValueError("ATOMIC_POSITIONS block is empty.")

    return {"cell": cell, "atoms": atoms}


def find_geometry_blocks(lines: list[str]) -> list[tuple[int, int]]:
    blocks = []
    cell_indices = [idx for idx, line in enumerate(lines) if line.lstrip().startswith("CELL_PARAMETERS")]
    for cell_idx in cell_indices:
        atomic_idx = None
        for idx in range(cell_idx + 1, min(cell_idx + 12, len(lines))):
            if lines[idx].lstrip().startswith("ATOMIC_POSITIONS"):
                atomic_idx = idx
                break
        if atomic_idx is not None:
            blocks.append((cell_idx, atomic_idx))
    return blocks


def find_final_geometry_block(lines: list[str]) -> tuple[int, int] | None:
    begin_indices = [idx for idx, line in enumerate(lines) if line.strip() == "Begin final coordinates"]
    if not begin_indices:
        return None

    begin_idx = begin_indices[-1]
    end_idx = next(
        (idx for idx in range(begin_idx + 1, len(lines)) if lines[idx].strip() == "End final coordinates"),
        len(lines),
    )

    cell_idx = None
    atomic_idx = None
    for idx in range(begin_idx + 1, end_idx):
        stripped = lines[idx].lstrip()
        if stripped.startswith("CELL_PARAMETERS") and cell_idx is None:
            cell_idx = idx
        elif stripped.startswith("ATOMIC_POSITIONS") and cell_idx is not None:
            atomic_idx = idx
            break

    if cell_idx is None or atomic_idx is None:
        return None
    return cell_idx, atomic_idx


def extract_structure(qe_output: Path, which: str) -> dict:
    lines = qe_output.read_text().splitlines()
    alat_angstrom = parse_alat_angstrom(lines)

    if which == "last":
        final_block = find_final_geometry_block(lines)
        if final_block is not None:
            return parse_geometry_block(lines, final_block[0], final_block[1], alat_angstrom)

    blocks = find_geometry_blocks(lines)
    if not blocks:
        raise ValueError(f"No CELL_PARAMETERS/ATOMIC_POSITIONS blocks found in {qe_output}.")

    cell_idx, atomic_idx = blocks[0] if which == "first" else blocks[-1]
    return parse_geometry_block(lines, cell_idx, atomic_idx, alat_angstrom)


def ensure_vasp_suffix(path: Path) -> Path:
    return path if path.suffix == ".vasp" else path.with_suffix(".vasp")


def write_vasp(output: Path, structure: dict) -> None:
    atoms = structure["atoms"]

    symbols = [symbol for symbol, _ in atoms]
    unique_symbols: list[str] = []
    for symbol in symbols:
        if symbol not in unique_symbols:
            unique_symbols.append(symbol)

    grouped_positions = []
    counts = []
    for symbol in unique_symbols:
        positions = [coords for atom_symbol, coords in atoms if atom_symbol == symbol]
        grouped_positions.extend(positions)
        counts.append(len(positions))

    lines = [
        "  ".join(unique_symbols),
        "  1.0000000000000000",
    ]
    for vector in structure["cell"]:
        lines.append(f" {vector[0]:.14f} {vector[1]:.14f} {vector[2]:.14f}")
    lines.append("  ".join(f"{symbol:>2}" for symbol in unique_symbols))
    lines.append("  ".join(str(count) for count in counts))
    lines.append("Direct")
    for coords in grouped_positions:
        lines.append(f" {coords[0]:.14f} {coords[1]:.14f} {coords[2]:.14f}")

    output.write_text("\n".join(lines) + "\n")


def output_paths(qe_output: Path, output_arg: str | None, both: bool) -> tuple[Path | None, Path | None]:
    if both:
        if output_arg:
            base = Path(output_arg).expanduser()
            parent = base.parent
            stem = base.stem
        else:
            parent = qe_output.parent
            stem = qe_output.stem
        return parent / f"{stem}_first.vasp", parent / f"{stem}_last.vasp"

    if output_arg:
        path = ensure_vasp_suffix(Path(output_arg).expanduser())
    else:
        path = qe_output.with_suffix(".vasp")
    return path, path


def main() -> None:
    args = parse_args()

    qe_output = Path(args.qe_output).expanduser().resolve()
    if not qe_output.is_file():
        raise FileNotFoundError(f"QE output file not found: {qe_output}")

    extract_first = args.first
    extract_last = args.last
    if args.both:
        extract_first = True
        extract_last = True
    elif not extract_first and not extract_last:
        extract_last = True

    first_output, last_output = output_paths(qe_output, args.output, args.both)

    if extract_first:
        structure = extract_structure(qe_output, "first")
        assert first_output is not None
        write_vasp(first_output, structure)
        print(f"Wrote first structure: {first_output}")

    if extract_last:
        structure = extract_structure(qe_output, "last")
        assert last_output is not None
        write_vasp(last_output, structure)
        print(f"Wrote last structure: {last_output}")


if __name__ == "__main__":
    main()
