&control
    calculation = 'vc-relax',
    prefix = 'PbTiO3',
    outdir = './tmp/',
    pseudo_dir = '/usr/local/pseudo/',
    etot_conv_thr = 1.0d-5,
    forc_conv_thr = 1.0d-3
/
&system
    ibrav = 0,
    nat = 5,
    ntyp = 3,
    ecutwfc = 50,
    ecutrho = 400,
/
&electrons
    mixing_beta = 0.7,
/
&ions
    ion_dynamics = 'bfgs',
/
&cell
    cell_dynamics = 'bfgs',
    press = 0.0,
/
