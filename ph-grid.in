&INPUTPH
! tr2_ph: Convergence threshold for phonons (linear-response SCF cycle).
!         Smaller values = more precise but slower. 1.0d-14 is tight.
  tr2_ph = 1.0d-14,

! prefix: Must match the prefix used in the preceding pw.x SCF calculation.
!         This tells ph.x where to find the required data files.
  prefix = 'pto',

! outdir: Directory where QE stores temporary files (charge density, wavefunctions).
!         Should match the outdir used in pw.x, typically './tmp/' or similar.
  outdir = './tmp/',

! fildyn: Base name for the output dynamical matrix file.
!         Creates 'pto.gamma.dyn' for gamma point (q=0).
  fildyn = 'pto.dyn',

! epsil: If .true., calculates the dielectric constant (effective charges).
!        Set to .true. for piezo/ferroelectric materials, .false. otherwise.
  epsil  = .true.

! ldisp: If .true., enables phonon calculation on a grid of q-points.
  ldisp  = .true.

! nq1, nq2, nq3: Number of q-points along each crystal axis for the phonon grid.
  nq1 = 2, nq2 = 2, nq3 = 2
/