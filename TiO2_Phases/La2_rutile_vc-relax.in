&CONTROL
  calculation    = 'vc-relax',
  prefix         = 'la2_rutile',
  pseudo_dir     = './rutile_psps',
  outdir         = './tmp/',
  tstress        = .true.,
  tprnfor        = .true.,
  etot_conv_thr  = 1.0d-5,
  forc_conv_thr  = 1.0d-4,
  nstep          = 100
/

&SYSTEM
  nosym          = .true.
  ibrav          = 0,
  nat            = 48,
  ntyp           = 3,
  ecutwfc        = 50.0,
  ecutrho        = 250.0,
  occupations    = 'smearing',
  smearing       = 'mv',
  degauss        = 0.001
/

&ELECTRONS
  mixing_beta    = 0.5,
  conv_thr       = 1.0d-8
/

&IONS
  upscale        = 100.D0
/

&CELL
  cell_dynamics  = 'bfgs',
  press_conv_thr = 0.5d0,
  cell_dofree    = 'all'
/

