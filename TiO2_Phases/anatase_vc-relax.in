&CONTROL
  calculation    = 'vc-relax',
  prefix         = 'la_anatase',
  pseudo_dir     = './anatase_psps',
  outdir         = './tmp/',
  tstress        = .true.,
  tprnfor        = .true.,
  etot_conv_thr  = 1.0d-5,
  forc_conv_thr  = 1.0d-4,
  nstep          = 100
/

&SYSTEM
  nosym          = .true.
  ibrav          = 0,
  nat            = 24,
  ntyp           = 3,
  ecutwfc        = 50.0,
  ecutrho        = 250.0,
  occupations    = 'smearing',
  smearing       = 'mv',
  degauss        = 0.001
/

&ELECTRONS
  mixing_beta    = 0.5,
  conv_thr       = 1.0d-8
/

&IONS
  upscale        = 100.D0
/

&CELL
  cell_dynamics  = 'bfgs',
  press_conv_thr = 0.5d0,
  cell_dofree    = 'all'
/

ATOMIC_SPECIES
La 138.905  la_pbesol_v1.uspp.F.UPF
Ti  47.867  ti_pbesol_v1.4.uspp.F.UPF
O   15.999  o_pbesol_v1.2.uspp.F.UPF

