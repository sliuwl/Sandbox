! TiO2 + La doping (1x1x2 supercell)
! 1 La replaces 1 Ti: La1Ti7O16
! Space group: Pca21

&CONTROL
  calculation    = 'vc-relax'
  prefix         = 'tio2_la'
  pseudo_dir     = './psps'
  outdir         = './tmp/'
  tstress        = .true.
  tprnfor        = .true.
  etot_conv_thr  = 1.0d-5
  forc_conv_thr  = 1.0d-4
  nstep          = 100
/

&SYSTEM
  nosym          = .false.         ! Enable symmetry
  ibrav          = 0
  nat            = 24
  ntyp           = 3
  ecutwfc        = 50.0
  ecutrho        = 250.0
  occupations    = 'smearing'
  smearing       = 'mv'
  degauss        = 0.001
/

&ELECTRONS
  mixing_mode    = 'plain'
  mixing_beta    = 0.5
  conv_thr       = 1.0d-8
/

&IONS
  ion_dynamics   = 'bfgs'
  upscale        = 100.D0
/

&CELL
  cell_dynamics  = 'bfgs'
  press_conv_thr = 0.5d0
  cell_dofree    = 'xyz'
/

ATOMIC_SPECIES
La  138.905  la_pbesol_v1.uspp.F.UPF
Ti  47.867  ti_pbesol_v1.4.uspp.F.UPF
O   15.999  o_pbesol_v1.2.uspp.F.UPF

K_POINTS {automatic}
6 6 4 0 0 0

! 1x1x2 supercell
CELL_PARAMETERS (angstrom)
   4.86177554     0.00000000     0.00000000
   0.00000000     4.63286274     0.00000000
   0.00000000     0.00000000     9.42936372

