! Ca2F2 / TiO2 / Ca2F2 heterostructure
! O-terminated TiO2 (both interfaces)
! Total: 32 atoms

&CONTROL
  calculation    = 'vc-relax'
  prefix         = 'caf2_tio2'
  pseudo_dir     = './psps'
  outdir         = './tmp/'
  tstress        = .true.
  tprnfor        = .true.
  etot_conv_thr  = 1.0d-5
  forc_conv_thr  = 1.0d-4
  nstep          = 100
/

&SYSTEM
  nosym          = .false.
  ibrav          = 0
  nat            = 32
  ntyp           = 4
  ecutwfc        = 50.0
  ecutrho        = 250.0
  occupations    = 'smearing'
  smearing       = 'mv'
  degauss        = 0.001
/

&ELECTRONS
  mixing_mode    = 'plain'
  mixing_beta    = 0.5
  conv_thr       = 1.0d-8
/

&IONS
  ion_dynamics   = 'bfgs'
  upscale        = 100.D0
/

&CELL
  cell_dynamics  = 'bfgs'
  press_conv_thr = 0.5d0
  cell_dofree    = 'xy'
/

